// 1. DATASOURCE AND GENERATOR
datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

generator client {
  provider = "prisma-client-js"
}

// 2. ENUMS (as string literals for SQLite compatibility)
enum CompetitionType {
  LEAGUE
  CUP
  PLAYOFF
}

enum LeagueLevel {
  EREDIVISIE
  KKD
  TWEEDE_DIVISIE
  DERDE_DIVISIE
  VIERDE_KLASSE
  VIJFTIGE_KLASSE
  ZONDAG_AMATEURS
  ZATERDAG_AMATEURS
}

// 3. COMPETITION STRUCTURE
model Competition {
  id          Int       @id @default(autoincrement())
  name        String
  type        CompetitionType
  level       LeagueLevel
  season      String
  country     String    @default("Netherlands")
  isActive    Boolean   @default(true)
  teams       TeamInCompetition[]
  fixtures    Fixture[]
  parentCompetition   Competition? @relation("CompetitionHierarchy", fields: [parentCompetitionId], references: [id])
  parentCompetitionId  Int?
  childCompetitions    Competition[] @relation("CompetitionHierarchy")
  promotionSpots       Int?
  relegationSpots      Int?
  playoffSpots         Int?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model TeamInCompetition {
  id            Int       @id @default(autoincrement())
  team          Club      @relation(fields: [teamId], references: [id])
  teamId        Int
  competition   Competition @relation(fields: [competitionId], references: [id])
  competitionId Int
  position      Int
  played        Int       @default(0)
  won           Int       @default(0)
  drawn         Int       @default(0)
  lost          Int       @default(0)
  goalsFor      Int       @default(0)
  goalsAgainst  Int       @default(0)
  goalDifference Int      @default(0)
  points        Int       @default(0)
  form          String?   // Last 5 matches (e.g., "WWLWD")
  homeForm      String?
  awayForm      String?
  promotion     Boolean   @default(false)
  relegation    Boolean   @default(false)
  playoff       Boolean   @default(false)
  notes         String?
  
  @@unique([teamId, competitionId])
  @@index([competitionId, position])
  @@index([points, goalDifference, goalsFor])
}

model Fixture {
  id              Int       @id @default(autoincrement())
  competition     Competition @relation(fields: [competitionId], references: [id])
  competitionId   Int
  homeTeam        Club      @relation("HomeFixtures", fields: [homeTeamId], references: [id])
  homeTeamId      Int
  awayTeam        Club      @relation("AwayFixtures", fields: [awayTeamId], references: [id])
  awayTeamId      Int
  homeScore       Int?
  awayScore       Int?
  matchDay        Int
  matchDate       DateTime
  isPlayed        Boolean   @default(false)
  isPostponed     Boolean   @default(false)
  attendance      Int?
  stadium         String?
  referee         String?
  events          MatchEvent[]
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  @@index([competitionId])
  @@index([homeTeamId])
  @@index([awayTeamId])
  @@index([matchDay])
  @@index([matchDate])
}

model MatchEvent {
  id          Int       @id @default(autoincrement())
  fixture     Fixture   @relation(fields: [fixtureId], references: [id])
  fixtureId   Int
  eventType   String    // GOAL, YELLOW_CARD, RED_CARD, SUBSTITUTION, etc.
  minute      Int
  player      Player?   @relation(fields: [playerId], references: [id])
  playerId    Int?
  club        Club      @relation(fields: [clubId], references: [id])
  clubId      Int
  description String?
  isHomeTeam  Boolean
  
  @@index([fixtureId])
  @@index([playerId])
  @@index([clubId])
}

// 4. LEAGUE MODEL
model League {
  id          Int       @id @default(autoincrement())
  name        String
  level       String    // e.g., "Eredivisie", "Keuken Kampioen Divisie"
  country     String    @default("Netherlands")
  tier        Int       // 1 for top division, 2 for second, etc.
  clubs       Club[]
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  
  @@index([name])
  @@index([level])
  @@index([country])
  @@index([tier])
}

// 5. CLUB FINANCES AND FACILITIES
model ClubFinances {
  id              Int       @id @default(autoincrement())
  club            Club      @relation(fields: [clubId], references: [id])
  clubId          Int       @unique
  season          String    // e.g., "2023/2024"
  matchdayIncome  Float     @default(0)
  seasonTicketIncome Float   @default(0)
  sponsorship     Float     @default(0)
  prizeMoney      Float     @default(0)
  playerSales     Float     @default(0)
  playerWages     Float     @default(0)
  staffWages      Float     @default(0)
  facilityCosts   Float     @default(0)
  youthAcademy    Float     @default(0)
  transferBudget  Float     @default(0)
  currentBalance  Float     @default(0)
  
  // Timestamps
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  @@unique([clubId, season])
}

model ClubFacility {
  id              Int       @id @default(autoincrement())
  club            Club      @relation(fields: [clubId], references: [id])
  clubId          Int       @unique
  stadiumLevel    Int       @default(1)
  trainingGround  Int       @default(1)
  youthAcademy    Int       @default(1)
  youthFacilities Int       @default(1)
  scoutingNetwork Int       @default(1)
  
  // Timestamps
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model ClubSeasonStats {
  id              Int       @id @default(autoincrement())
  club            Club      @relation(fields: [clubId], references: [id])
  clubId          Int
  season          String    // e.g., "2023/2024"
  matchesPlayed   Int       @default(0)
  wins            Int       @default(0)
  draws           Int       @default(0)
  losses          Int       @default(0)
  goalsFor        Int       @default(0)
  goalsAgainst    Int       @default(0)
  cleanSheets     Int       @default(0)
  yellowCards     Int       @default(0)
  redCards        Int       @default(0)
  
  // League position and points
  position        Int?
  points          Int       @default(0)
  
  // Timestamps
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  @@unique([clubId, season])
  @@index([season, points])
}

// 5. CLUB MODEL
model Club {
  id              Int       @id @default(autoincrement())
  name            String
  shortName       String?
  founded         Int?
  city            String?
  stadium         String?
  capacity        Int?
  reputation      Int?      @default(50) // 1-100 scale
  financialStatus Int?      @default(50) // 1-100 scale
  
  // Team performance
  morale          Int?      @default(70) // 1-100 scale
  form            String?   // Last 5 matches (e.g., "WWLWD")
  boardExpectation String?  // e.g., 'title-challenge', 'europe', 'mid-table', 'avoid-relegation'
  
  // League and competition
  leagueId        Int?
  league          League?   @relation(fields: [leagueId], references: [id])
  
  // Team colors
  primaryColor    String?   // Hex color
  secondaryColor  String?   // Hex color
  
  // Relations
  players         Player[]
  staff           Staff[]
  homeFixtures    Fixture[] @relation("HomeFixtures")
  awayFixtures    Fixture[] @relation("AwayFixtures")
  matchEvents     MatchEvent[]
  competitions    TeamInCompetition[]
  transferListings TransferListing[]
  offersMade      TransferOffer[] @relation("FromClub")
  offersReceived  TransferOffer[] @relation("ToClub")
  finances        ClubFinances?
  facility        ClubFacility?
  clubSeasonStats ClubSeasonStats[]
  
  // Financials
  balance         Float     @default(0)
  transferBudget  Float     @default(0)
  wageBudget      Float     @default(0)
  
  // Stats
  averageAttendance Int?    @default(0)
  
  // Jong team relationship
  isJongTeam      Boolean   @default(false)
  parentClubId    Int?
  parentClub      Club?     @relation("JongTeams", fields: [parentClubId], references: [id])
  jongTeams       Club[]    @relation("JongTeams")
  
  // Metadata
  isUserControlled Boolean  @default(false)
  isActive        Boolean   @default(true)
  
  // Timestamps
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  @@index([name])
  @@index([city])
  @@index([reputation])
}

// 5. PLAYER MODEL
model Player {
  id              Int       @id @default(autoincrement())
  firstName       String
  lastName        String
  dateOfBirth     DateTime
  nationality     String    @default("Netherlands")
  height          Int?      // in cm
  weight          Int?      // in kg
  
  // Current club
  currentClub     Club?     @relation(fields: [currentClubId], references: [id])
  currentClubId   Int?
  
  // Contract
  contractStart   DateTime?
  contractEnd     DateTime?
  weeklyWage      Float?    // in euros
  value           Float?    // estimated market value in euros
  
  // Player attributes
  position        String    // e.g., "ST", "CM", "CB"
  preferredFoot   String?   // "LEFT" or "RIGHT"
  
  // Stats
  appearances     Int       @default(0)
  goals           Int       @default(0)
  assists         Int       @default(0)
  yellowCards     Int       @default(0)
  redCards        Int       @default(0)
  
  // Relations
  transferOffers  TransferOffer[] @relation("PlayerTransferOffers")
  transferListings TransferListing[]
  matchEvents     MatchEvent[]
  
  // Metadata
  isInjured      Boolean   @default(false)
  injuryEndDate   DateTime?
  isSuspended    Boolean   @default(false)
  suspensionEndDate DateTime?
  
  // Timestamps
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  // Computed fields (virtual, not stored in DB)
  @@map("players")
  @@index([firstName, lastName])
  @@index([currentClubId])
  @@index([nationality])
  @@index([position])
  @@index([value])
}

// 6. STAFF MODEL
model Staff {
  id              Int       @id @default(autoincrement())
  firstName       String
  lastName        String
  dateOfBirth     DateTime
  nationality     String
  role            String    // e.g., "MANAGER", "ASSISTANT", "SCOUT"
  
  // Current club
  club            Club      @relation(fields: [clubId], references: [id])
  clubId          Int
  
  // Contract
  contractStart   DateTime
  contractEnd     DateTime
  weeklyWage      Float     // in euros
  
  // Attributes based on role
  ability         Int?      // 1-100
  potential       Int?      // 1-100
  
  // Manager-specific
  preferredFormation String? // e.g., "4-3-3", "4-4-2"
  
  // Timestamps
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  @@index([clubId])
  @@index([role])
}

// 7. TRANSFER LISTING MODEL
model TransferListing {
  id              Int       @id @default(autoincrement())
  player          Player    @relation(fields: [playerId], references: [id])
  playerId        Int
  club            Club      @relation(fields: [clubId], references: [id])
  clubId          Int
  askingPrice     Float
  listingType     String    @default("TRANSFER") // TRANSFER, LOAN, BOTH
  loanFee         Float?
  wageContribution Float?
  status          String    @default("ACTIVE")  // ACTIVE, COMPLETED, CANCELLED, EXPIRED
  deadline        DateTime?
  offers          TransferOffer[]
  
  // Timestamps
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  @@index([playerId])
  @@index([clubId])
  @@index([status])
  @@index([deadline])
}

// 8. TRANSFER OFFER MODEL
model TransferOffer {
  id              Int       @id @default(autoincrement())
  player          Player    @relation("PlayerTransferOffers", fields: [playerId], references: [id])
  playerId        Int
  fromClub        Club      @relation("FromClub", fields: [fromClubId], references: [id])
  fromClubId      Int
  toClub          Club      @relation("ToClub", fields: [toClubId], references: [id])
  toClubId        Int
  listing         TransferListing? @relation(fields: [listingId], references: [id])
  listingId       Int?
  
  // Offer details
  status          String    @default("PENDING") // PENDING, ACCEPTED, REJECTED, COUNTERED, WITHDRAWN
  amount          Float
  isLoan          Boolean   @default(false)
  loanEndDate     DateTime?
  wageContribution Float?
  transferFee     Float?
  
  // Contract details
  contractLength  Int?      // in years
  weeklyWage      Float?    // offered weekly wage
  
  // Additional clauses
  addonClauses    Json?     // Performance bonuses, sell-on clauses, etc.
  
  // Communication
  message         String?
  response        String?
  initiator       String?   // 'user' or 'AI'
  
  // For counter offers
  counteredAmount Float?
  
  // Timestamps
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deadline        DateTime? // Deadline for response
  
  // Audit trail
  history         Json?     // History of changes to the offer
  
  // Loan with option to buy
  isLoanWithOption Boolean  @default(false)
  optionToBuyFee  Float?
  
  @@index([playerId])
  @@index([fromClubId])
  @@index([toClubId])
  @@index([listingId])
  @@index([status])
  @@index([deadline])
}
